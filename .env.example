APP_NAME=FuFu Shopping
APP_VERSION=1.0.0

# API
API_BASE_URL=http://<YOUR_SERVER_IP>:8000/api

# Cloudinary (https://cloudinary.com → Settings → Upload Presets → Add Unsigned preset)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# PayPal Sandbox (https://developer.paypal.com → Apps & Credentials → Sandbox → Create App)
PAYPAL_CLIENT_ID=your_paypal_sandbox_client_id
PAYPAL_SECRET_KEY=your_paypal_sandbox_secret_key
